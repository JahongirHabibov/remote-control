# ─────────────────────────────────────────────────────────────────────────────
# .env.example — POS Remote Control VPS Configuration
#
# Copy to .env and fill in all values:
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────

# ── Domain ────────────────────────────────────────────────────────────────────
# The subdomain pointing to this VPS (DNS A-record must exist)
DOMAIN=remote.domain.com

# Email for Let's Encrypt certificate notifications
CERTBOT_EMAIL=admin@domain.com

# ── WireGuard Server ──────────────────────────────────────────────────────────
# UDP port for WireGuard (must be open in firewall)
WG_PORT=51820

# VPN subnet — server gets .1, devices get .2, .3, .4, ...
WG_SUBNET=10.8.0.0/24
WG_SERVER_IP=10.8.0.1/24

# Network interface with internet access (used for NAT in WG PostUp/PostDown)
# Find yours with: ip route get 1.1.1.1 | awk '{print $5; exit}'
WG_INET_IFACE=eth0

# ── PostgreSQL (Guacamole database) ───────────────────────────────────────────
POSTGRES_DB=guacamole_db
POSTGRES_USER=guacamole
# Generate with: openssl rand -base64 32
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here

# ── Guacamole Admin ───────────────────────────────────────────────────────────
# Initial admin account (change password after first login!)
GUAC_ADMIN_USER=admin
# Generate with: openssl rand -base64 16
GUAC_ADMIN_PASSWORD=CHANGE_ME_admin_password_here

# ── Guacamole Docker image version ───────────────────────────────────────────
GUACAMOLE_VERSION=1.5.5

# ── Timezone (required by fail2ban container for correct log timestamps) ──────
TZ=UTC
