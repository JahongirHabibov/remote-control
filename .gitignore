# ── Secrets & generated configs ───────────────────────────────────────────────
.env
*.key
*.pem
*.crt

# ── WireGuard (actual server config with private key) ─────────────────────────
wireguard/wg0.conf
wireguard/server-private.key
wireguard/server-public.key

