guacamole/guacamole.properties
guacamole/init/
guacamole/extensions/*.jar

# ── Backups ───────────────────────────────────────────────────────────────────
backups/

# ── Certbot (generated certs + webroot) ──────────────────────────────────────
certbot/certs/
certbot/www/

# ── Logs ──────────────────────────────────────────────────────────────────────
logs/

# ── Docker volumes (if mapped locally) ───────────────────────────────────────
postgres-data/

